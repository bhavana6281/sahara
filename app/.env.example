# Copy to app/.env and fill in real values. NEVER commit the real .env.
# All three are required — there is no local fallback mode.
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi-your-token-here
WAREHOUSE_ID=your_sql_warehouse_id

TRUST_TABLE=workspace.default.facility_trust
PLANNER_ACTIONS_TABLE=workspace.default.planner_actions

# NL-query LLM (optional feature — app runs fine without these, NL search just
# degrades to keyword matching). Can be a narrowly-scoped token distinct from
# DATABRICKS_TOKEN above (e.g. a token with only serving-endpoints/ai-gateway
# access, no "sql" scope).
LLM_TOKEN=dapi-your-llm-token-here
LLM_BASE_URL=https://your-workspace.cloud.databricks.com/ai-gateway/mlflow/v1
LLM_ENDPOINT=system.ai.llama-4-maverick
